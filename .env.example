# Copy this file to .env and fill in your own values.
# cp .env.example .env

# --- Server ---
PORT=3000
NODE_ENV=development

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=github_analyzer
DB_CONNECTION_LIMIT=10

# --- GitHub API ---
# Optional but strongly recommended. Without a token, GitHub limits
# unauthenticated requests to 60/hour per IP, which is easy to exhaust.
# A personal access token (no special scopes needed, just "public_repo"
# read access / classic token with no scopes selected) raises this to
# 5000/hour. Generate one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# --- Cache ---
# How long (seconds) a freshly-analyzed username is cached before a
# repeat POST /analyze call will re-fetch from GitHub instead of
# returning the cached result instantly.
CACHE_TTL_SECONDS=300

# --- Rate limiting (protects this API from abuse) ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
